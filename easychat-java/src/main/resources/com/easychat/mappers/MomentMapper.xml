            <if test="bean.createTime!=null">#{bean.createTime},</if>
            <if test="bean.updateTime!=null">#{bean.updateTime},</if>
        </trim>
    </insert>

    <insert id="insertBatch" parameterType="com.easychat.entity.po.Moment" useGeneratedKeys="true" keyProperty="id">
        insert into moment(
        user_id,content,media_type,location,visibility,visible_list,invisible_list,status,create_time,update_time
        ) values
        <foreach collection="list" item="item" separator=",">
            (
            #{item.userId},
            #{item.content},
            #{item.mediaType},
            #{item.location},
            #{item.visibility},
            #{item.visibleList},
            #{item.invisibleList},
            #{item.status},
            #{item.createTime},
