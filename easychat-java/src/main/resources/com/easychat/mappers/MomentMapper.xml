    <sql id="base_column_list">
        id,user_id,content,media_type,location,visibility,visible_list,invisible_list,status,create_time,update_time
    </sql>

    <sql id="base_condition_field">
        <if test="query.id != null">
            and id = #{query.id}
        </if>
        <if test="query.userId != null and query.userId!=''">
            and user_id = #{query.userId}
        </if>
        <if test="query.visibility != null">
            and visibility = #{query.visibility}
        </if>
        <if test="query.status != null">
            and status = #{query.status}
        </if>
        <if test="query.startCreateTime != null">
            and create_time &gt;= #{query.startCreateTime}
        </if>
        <if test="query.endCreateTime != null">
            and create_time &lt;= #{query.endCreateTime}
        </if>
    </sql>

    <sql id="base_condition">
        <where>
            <include refid="base_condition_field"/>
        </where>
    </sql>

    <select id="selectList" resultMap="base_result_map">
        select
        <include refid="base_column_list"/>
        from moment
        <include refid="base_condition"/>
        <if test="query.orderBy!=null">
            order by ${query.orderBy}
        </if>
        <if test="query.simplePage!=null">
            limit #{query.simplePage.start},#{query.simplePage.end}
        </if>
    </select>

    <select id="selectCount" resultType="java.lang.Integer">
        select count(1) from moment
        <include refid="base_condition"/>
    </select>

    <insert id="insert" parameterType="com.easychat.entity.po.Moment" useGeneratedKeys="true" keyProperty="bean.id">
