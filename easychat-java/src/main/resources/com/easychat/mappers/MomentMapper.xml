            #{item.location},
            #{item.visibility},
            #{item.visibleList},
            #{item.invisibleList},
            #{item.status},
            #{item.createTime},
            #{item.updateTime}
            )
        </foreach>
        on duplicate key update
        user_id = values(user_id),
        content = values(content),
        media_type = values(media_type),
