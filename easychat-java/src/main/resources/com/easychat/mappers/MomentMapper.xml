            <if test="bean.status!=null">status,</if>
            <if test="bean.createTime!=null">create_time,</if>
            <if test="bean.updateTime!=null">update_time,</if>
        </trim>
        <trim prefix="values(" suffix=")" suffixOverrides=",">
