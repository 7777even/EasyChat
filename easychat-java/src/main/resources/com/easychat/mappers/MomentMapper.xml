    <insert id="insertOrUpdateBatch" parameterType="com.easychat.entity.po.Moment">
        insert into moment(
        id,user_id,content,media_type,location,visibility,visible_list,invisible_list,status,create_time,update_time
        ) values
        <foreach collection="list" item="item" separator=",">
